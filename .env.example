# Real-Time Retail Insights Platform environment template
# Copy this file to .env and replace placeholder values before running the platform.
# Do not commit real secrets.

# Project
PROJECT_NAME=retail-insights
ENVIRONMENT=dev

# AWS credentials and account metadata
AWS_REGION=us-east-1
AWS_PROFILE=default
AWS_ACCESS_KEY_ID=replace-with-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-secret-access-key
AWS_SESSION_TOKEN=
AWS_ACCOUNT_ID=123456789012

# Terraform variables. Terraform automatically reads TF_VAR_* values.
TF_VAR_aws_region=us-east-1
TF_VAR_environment=dev
TF_VAR_redshift_username=admin
TF_VAR_redshift_password=replace-with-strong-password
TF_VAR_databricks_workspace_url=https://replace-with-workspace.cloud.databricks.com
TF_VAR_databricks_token=replace-with-databricks-token
TF_VAR_notification_email=alerts@example.com

# S3 buckets used by Terraform, Databricks notebooks, and Airflow DAGs.
S3_RAW_BUCKET=retail-insights-raw-dev
S3_PROCESSED_BUCKET=retail-insights-processed-dev
S3_CURATED_BUCKET=retail-insights-curated-dev
S3_TERRAFORM_STATE_BUCKET=retail-insights-terraform-state

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_CLICKSTREAM=retail_clickstream
KAFKA_TOPIC_TRANSACTIONS=retail_transactions
KAFKA_TOPIC_INVENTORY=retail_inventory
KAFKA_EVENTS_PER_SECOND=10

# Databricks
DATABRICKS_HOST=https://replace-with-workspace.cloud.databricks.com
DATABRICKS_TOKEN=replace-with-databricks-token
DATABRICKS_SECRET_SCOPE=retail-insights
DATABRICKS_CLICKSTREAM_JOB_ID=replace-with-clickstream-job-id
DATABRICKS_TRANSACTION_JOB_ID=replace-with-transaction-job-id
DATABRICKS_INVENTORY_JOB_ID=replace-with-inventory-job-id

# Redshift
REDSHIFT_HOST=replace-with-redshift-endpoint
REDSHIFT_PORT=5439
REDSHIFT_DATABASE=retail_analytics
REDSHIFT_USERNAME=admin
REDSHIFT_PASSWORD=replace-with-redshift-password
REDSHIFT_CLUSTER_ID=retail-insights-dev
REDSHIFT_IAM_ROLE_ARN=arn:aws:iam::123456789012:role/RedshiftS3Role

# Airflow variables consumed by airflow/dags/retail_insights_pipeline.py.
AIRFLOW_VAR_CLICKSTREAM_PROCESSING_JOB_ID=replace-with-clickstream-job-id
AIRFLOW_VAR_TRANSACTION_PROCESSING_JOB_ID=replace-with-transaction-job-id
AIRFLOW_VAR_INVENTORY_PROCESSING_JOB_ID=replace-with-inventory-job-id
AIRFLOW_VAR_KAFKA_DATA={}
AIRFLOW_VAR_REDSHIFT_CLUSTER_ID=retail-insights-dev
AIRFLOW_VAR_REDSHIFT_DATABASE=retail_analytics
AIRFLOW_VAR_REDSHIFT_USERNAME=admin
AIRFLOW_VAR_REDSHIFT_PASSWORD=replace-with-redshift-password
AIRFLOW_VAR_REDSHIFT_HOST=replace-with-redshift-endpoint
AIRFLOW_VAR_AWS_ACCOUNT_ID=123456789012
AIRFLOW_VAR_DATABRICKS_HOST=https://replace-with-workspace.cloud.databricks.com
AIRFLOW_VAR_DATABRICKS_TOKEN=replace-with-databricks-token

# Local service URLs
AIRFLOW_URL=http://localhost:8080
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-grafana-password
